    <string name="onboarding_subtitle">A quick tour of local Java running on your tablet</string>

    <string name="onboarding_runner_title">Run Java locally</string>
    <string name="onboarding_runner_body">Open a Java file with a main method, then press RUN. J-IDE Lite uses an embedded local runner, so you do not need Termux or any remote service.</string>

    <string name="onboarding_maven_title">Use BUILD for Maven</string>
    <string name="onboarding_maven_body">If your workspace contains pom.xml, press BUILD first to resolve Maven dependencies. Dependencies are cached locally, and RUN will compile with them automatically.</string>

    <string name="onboarding_share_title">Share code and learn shortcuts</string>
    <string name="onboarding_share_body">Use SHARE to send the current .java file through the Android share sheet. Tap KEYS or press Ctrl+/ to reopen keyboard shortcuts. Press Ctrl+? anytime to reopen this onboarding guide.</string>

